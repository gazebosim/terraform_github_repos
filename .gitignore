# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (not used - we use YAML config instead)
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore Mac .DS_Store files
.DS_Store

# Python virtual environment
.venv/
__pycache__/
*.pyc
.mypy_cache/

# Ignore lock files (optional, some teams prefer to commit this)
# .terraform.lock.hcl
